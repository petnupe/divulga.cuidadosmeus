# Configurações de E-mail (SMTP)
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_USER="seu-email@dominio.com"
SMTP_PASS="sua-senha-aqui"
SMTP_FROM="seu-email@dominio.com"

# Notificações Administrativas
ADMIN_NOTIFY_EMAIL="seu-email-pessoal@gmail.com"

# Configurações do Gateway de Pagamento (Asaas)
# Use 'sandbox' para testes e 'production' para o site real
ASAAS_ENV="sandbox"
ASAAS_BASE_URL="https://api-sandbox.asaas.com/v3/"
ASAAS_API_KEY="insira_sua_api_key_aqui"
TOKEN_ASAAS="insira_o_token_do_webhook_aqui"

# Caminhos de Log (Ajuste conforme o servidor)
# Exemplo Local: d:/Cursos_e_Labs/...
# Exemplo Produção: /home/usuario/public_html/storage/logs/asaas.log
ASAAS_LOG_PATH="caminho/para/o/arquivo/de/log"